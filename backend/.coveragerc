[run]
source = app
omit =
    # Old module kept for reference — replaced by AwsCostService
    app/services/aws_cost.py
    # Terminal display helper — only used by the old debug script
    app/utils/display.py
    app/utils/__init__.py
    # Empty placeholder folders
    app/routers/__init__.py
    app/schemas/__init__.py
    app/db/__init__.py
    app/models/__init__.py
    app/jobs/__init__.py
    app/api/__init__.py
    app/__init__.py

[report]
show_missing = true
skip_empty = true
