# Copy this file to backend/.env and fill in your real values.
# Never commit .env to git — it contains secrets.

# --- PostgreSQL (FastAPI app connection string) ---
# Must match the POSTGRES_* values in the root .env used by Docker Compose.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=postgresql://cloudguard:cloudguard_dev@localhost:5433/cloudguard

# --- AWS Credentials ---
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# --- App Settings ---
SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Auth / JWT (Phase 6.1) ---
# Signs login tokens. Use a long random string, distinct from SECRET_KEY.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# If left blank, the app falls back to SECRET_KEY (fine for local dev).
ACCESS_TOKEN_SECRET=change-this-to-another-long-random-string
# How long a login stays valid, in minutes (default 1440 = 24 hours).
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Encryption (Phase 6.2) ---
# Symmetric key used to encrypt each user's AWS secret access key at rest
# (Fernet). Generate a REAL key — do not ship this placeholder:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NOTE: this is an FYP-grade approach. A production system would keep this key
# in a managed KMS (e.g. AWS KMS / Secrets Manager) rather than an env var, and
# ideally avoid storing long-lived AWS secrets at all via IAM role assumption.
ENCRYPTION_KEY=generate-a-real-fernet-key-see-comment-above

# --- SendGrid email alerts (Phase 4) ---
# Get a free API key at https://app.sendgrid.com/settings/api_keys
# IMPORTANT: ALERT_SENDER_EMAIL must be a verified single sender — set one up
# at https://app.sendgrid.com/settings/sender_auth BEFORE running the app,
# otherwise SendGrid silently rejects every send.
SENDGRID_API_KEY=
ALERT_SENDER_EMAIL=your-verified-sender@example.com
ALERT_RECIPIENT_EMAIL=your-inbox@example.com
