# Copy this file to backend/.env and fill in your real values.
# Never commit .env to git — it contains secrets.

# --- PostgreSQL (FastAPI app connection string) ---
# Must match the POSTGRES_* values in the root .env used by Docker Compose.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=postgresql://cloudguard:cloudguard_dev@localhost:5433/cloudguard

# --- AWS Credentials ---
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# --- App Settings ---
SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- SendGrid email alerts (Phase 4) ---
# Get a free API key at https://app.sendgrid.com/settings/api_keys
# IMPORTANT: ALERT_SENDER_EMAIL must be a verified single sender — set one up
# at https://app.sendgrid.com/settings/sender_auth BEFORE running the app,
# otherwise SendGrid silently rejects every send.
SENDGRID_API_KEY=
ALERT_SENDER_EMAIL=your-verified-sender@example.com
ALERT_RECIPIENT_EMAIL=your-inbox@example.com
