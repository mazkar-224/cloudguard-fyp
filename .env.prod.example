# Copy to .env.prod and fill in REAL values:  cp .env.prod.example .env.prod
# .env.prod is gitignored — never commit real secrets.

# ── PostgreSQL (consumed by the `db` container) ──────────────────────────────
POSTGRES_USER=cloudguard
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=cloudguard

# ── Backend database connection ──────────────────────────────────────────────
# Points at the `db` service over the compose network (internal port 5432).
# The user/password/db MUST match the POSTGRES_* values above.
DATABASE_URL=postgresql://cloudguard:change-me-to-a-strong-password@db:5432/cloudguard

# ── AWS credentials (system/scheduler account) ───────────────────────────────
# Used by the background scheduler. Required for the app to boot. Per-user
# credentials entered in the Settings UI are stored encrypted in the DB and are
# separate from these. Use READ-ONLY IAM credentials here.
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# ── App secrets ──────────────────────────────────────────────────────────────
# SECRET_KEY / ACCESS_TOKEN_SECRET: any long random strings (keep them distinct).
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_SECRET=change-this-to-another-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# ENCRYPTION_KEY: a real Fernet key (encrypts users' AWS secrets at rest).
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=generate-a-real-fernet-key-see-comment-above

# ── Public hostname (consumed by Caddy) ──────────────────────────────────────
# DOMAIN drives the Caddy site block. Use `localhost` for a local prod test;
# use your real hostname (e.g. cloudguard.duckdns.org) on the EC2 box so Caddy
# obtains a Let's Encrypt cert automatically. Bare IPs do NOT work with LE.
DOMAIN=localhost
# Email Let's Encrypt uses to send cert-expiry warnings.
ADMIN_EMAIL=you@example.com

# ── Runtime ──────────────────────────────────────────────────────────────────
DEBUG=False
ENVIRONMENT=production
LOG_LEVEL=INFO

# Background scheduler (APScheduler). It runs in-process, so keep this `true`
# on exactly ONE backend instance. With multiple workers/replicas, set it
# `false` on the extras to avoid running each job more than once.
ENABLE_SCHEDULER=true

# ── SendGrid email alerts (optional — leave key blank to disable) ────────────
SENDGRID_API_KEY=
ALERT_SENDER_EMAIL=your-verified-sender@example.com
ALERT_RECIPIENT_EMAIL=your-inbox@example.com
