# Copy this file to .env (repo root) and fill in your values.
# Docker Compose reads this file automatically — never commit the real .env.

# --- PostgreSQL ---
POSTGRES_USER=cloudguard
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=cloudguard

# --- pgAdmin (web UI at http://localhost:5050) ---
PGADMIN_EMAIL=admin@cloudguard.dev
PGADMIN_PASSWORD=change-this-password
