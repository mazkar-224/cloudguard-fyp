# Keep the build context small and the image clean.

# Dependencies (reinstalled inside the image via `npm ci`)
node_modules/

# Prior build output (regenerated by `npm run build`)
dist/

# Secrets / local env
.env
.env.*
!.env.example

# VCS / editor / OS noise
.git/
.gitignore
.vscode/
.idea/
.DS_Store

# Misc
README.md
*.log
